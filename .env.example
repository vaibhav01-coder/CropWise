# Web app (Vite reads this from the repo root — see client/vite.config.js envDir)
# Get values: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional — OpenWeatherMap (adds air-quality API). If unset, dashboard uses Open-Meteo (no key).
# VITE_OPENWEATHER_API_KEY=

# Optional — in-app translation
# VITE_GOOGLE_TRANSLATE_API_KEY=

# Optional — Mandi API (default: Vite proxy to http://localhost:8000)
# VITE_MANDI_API_BASE=/mandi-api

# Optional — direct API origin for PMFBY PDF fetch (e.g. `vite preview` without proxy). Dev with `npm run dev` usually does not need this.
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000
