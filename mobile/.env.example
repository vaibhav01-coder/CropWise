# Expo / React Native — copy to .env in this folder
# Same Supabase project as web; use EXPO_PUBLIC_ prefix for bundled values.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Optional
# EXPO_PUBLIC_OPENWEATHER_API_KEY=
# EXPO_PUBLIC_MANDI_API_BASE=http://localhost:8000/mandi
